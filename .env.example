# VAPEX Backend Environment Configuration
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/vapex

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# MQTT
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=vapex
MQTT_PASSWORD=vapex_password

# WebSocket
WS_PORT=3001

# Rate limiting (see `src/app.js`: fixed 1-minute window for `/api/`)
RATE_LIMIT_MAX_REQUESTS=100

# CORS (production): comma-separated extra origins in addition to vapex.app defaults
# CORS_ORIGINS=https://your-frontend.example.com

# Logging
LOG_LEVEL=info
