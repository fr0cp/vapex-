# ─── Server ───────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ──────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vapex

# ─── JWT ──────────────────────────────────────
JWT_SECRET=vapex_dev_secret_change_in_production_32chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── MQTT (optional) ──────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ─── Rate Limiting ────────────────────────────
RATE_LIMIT_MAX_REQUESTS=1000

# ─── CORS (production comma-separated) ────────
CORS_ORIGINS=http://localhost:3000
